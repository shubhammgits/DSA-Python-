   "source": [
    "### FInd the missing number in a array"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "f02abe5d",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[1, 2, 3, 4, 5]\n",
      "[1, 4, 5]\n",
      "Missing number is 2\n"
     ]
    }
   ],
   "source": [
    "#brute:\n",
    "\n",
    "a = [1,4,5]\n",
    "n=5\n",
    "\n",
    "all = []\n",
    "for i in range(1,n+1):\n",
    "    all.append(i)\n",
    "print(all)\n",
    "print(a)\n",
    "\n",
    "for i in range(len(all)):\n",
    "    if a[i] != all[i]:\n",
    "        print(f'Missing number is {all[i]}')\n",
    "        break"
   ]
