   ],
   "source": [
    "#solution:\n",
    "\n",
    "\n",
    "arr = [7,1,5,3,6,4]\n",
    "n = len(arr)\n",
    "mini = arr[0]\n",
    "maxProfit = 0\n",
    "\n",
    "for i in range(1,n):\n",
    "    sellPrice = arr[i] - mini\n",
    "    maxProfit = max(maxProfit, sellPrice)\n",
    "\n",
    "    mini = min(mini, arr[i])\n",
    "\n",
    "print(maxProfit)"
   ]
