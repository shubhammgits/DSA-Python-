   "source": [
    "### Rotate an array by K places"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "13116d1c",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[2, 3, 4, 5, 1]\n"
     ]
    }
   ],
   "source": [
    "#left rotate an array by one place\n",
    "\n",
    "a = [1,2,3,4,5]\n",
    "temp = a[0]\n",
    "n = len(a)\n",
    "for i in range(1,n):\n",
    "    a[i-1] = a[i]\n",
    "    \n",
    "a[n-1]=temp\n",
    "print(a)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "f0ed2869",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[2, 2]\n"
     ]
    }
   ],
   "source": [
    "a = [1,2]\n",
    "a[0] = a[1]\n",
    "print(a)"
   ]
