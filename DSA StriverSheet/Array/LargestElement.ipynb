   "source": [
    "### Largest Element in an Array"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "4f14c108",
   "metadata": {},
   "source": [
    "### Brute force"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "712f9d9e",
   "metadata": {},
   "outputs": [],
   "source": [
    "l = [3,2,1,5,2]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "1e396a23",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Largest element is 5\n"
     ]
    }
   ],
   "source": [
    "largest = l[0]\n",
    "for i in range(len(l)):\n",
    "    if l[i] > largest:\n",
    "        largest=l[i]\n",
    "print(f'Largest element is {largest}')"
   ]
  },
